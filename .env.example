# ── Database ──────────────────────────────────────────────────────────────────
# When using docker-compose, DATABASE_URL is set automatically via environment.
# Only set this manually if running outside Docker or using an external DB.
POSTGRES_USER=mps
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mps_db
DATABASE_URL="postgresql://mps:CHANGE_ME@localhost:5432/mps_db?schema=public"

# ── Application ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
APP_NAME="МПС Система"

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Security secrets ─────────────────────────────────────────────────────────
# Generate both: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSWORD_PEPPER=CHANGE_ME
TOTP_ENCRYPTION_KEY=CHANGE_ME

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── SMTP / Email (Resend: smtp.resend.com, port 465, secure true) ────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_YOUR_API_KEY
SMTP_FROM=noreply@yourdomain.com

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Google Sheets Service Account ────────────────────────────────────────────
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# ── Admin user (created during seed) ─────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_USERNAME=admin
